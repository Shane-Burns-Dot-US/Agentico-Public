{
  "public_repo_url": "https://github.com/Shane-Burns-Dot-US/Agentico-Public.git",
  "public_repo_ssh": "git@github.com:Shane-Burns-Dot-US/Agentico-Public.git",
  "public_repo_owner": "Shane-Burns-Dot-US",
  "public_repo_name": "Agentico-Public",
  "repo_dir_name": "Agentico-Public",
  "forbidden_parent_dir": "Agentico",
  "gate_dir": ".public-gate",
  "public_staging_marker": ".PUBLIC_STAGING_ONLY",
  "min_gate_checks_required": 10,
  "local_only_dirs": ["private-drafts"],
  "blocked_filenames": [
    ".env",
    ".env.local",
    ".env.production",
    ".env.development",
    "auth.lock",
    "config.yaml",
    "models_dev_cache.json",
    "SOUL.md",
    "hermes",
    ".PRIVATE_WORKSPACE",
    "PUBLISH_APPROVED",
    "credentials.json",
    "secrets.json",
    "id_rsa",
    "id_ed25519",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx"
  ],
  "blocked_directory_names": [
    "sessions",
    "memories",
    "logs",
    "cache",
    "audio_cache",
    "image_cache",
    "state-snapshots",
    "pairing",
    "cron",
    "hooks",
    "bin",
    "skills",
    "public-publish",
    "node_modules",
    "__pycache__",
    ".venv",
    "venv"
  ],
  "blocked_path_substrings": [
    "/sessions/",
    "/memories/",
    "/logs/",
    "/.env",
    "/config.yaml",
    "/.PRIVATE_WORKSPACE",
    "sk-ant-",
    "sk-proj-",
    "sk-or-",
    "sk-live-",
    "ghp_",
    "gho_",
    "github_pat_",
    "xoxb-",
    "xoxp-",
    "AKIA",
    "BEGIN RSA PRIVATE KEY",
    "BEGIN OPENSSH PRIVATE KEY",
    "BEGIN EC PRIVATE KEY",
    "api_key",
    "api-key",
    "password_hash",
    "client_secret"
  ],
  "allowed_top_level_in_staging": [
    ".PUBLIC_STAGING_ONLY",
    ".public-gate",
    ".gitignore",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "DISCLAIMER.md",
    "LEGAL_NOTICE.md",
    "CODE_OF_CONDUCT.md",
    "docs",
    "src",
    "assets",
    "examples",
    "AGENTICO_ENTITY.json",
    "GATE_MANIFEST.json",
    "GITHUB_REPO.json",
    "AWAITING_APPROVAL.md",
    "private-drafts"
  ],
  "marketing_scan_globs": [
    "README.md",
    "CONTRIBUTING.md",
    "docs/*.md",
    "docs/blog/*.md",
    "docs/schema/*.jsonld.json",
    "AGENTICO_ENTITY.json"
  ],
  "marketing_scan_excluded_files": [
    "LEGAL_NOTICE.md",
    "DISCLAIMER.md",
    "LICENSE"
  ],
  "marketing_claim_patterns": [
    "(?i)\\bliability[- ]isolated\\b",
    "(?i)\\bcourt[- ]ready\\b",
    "(?i)\\bcourt[- ]visible\\b",
    "(?i)\\breal legal standing\\b",
    "(?i)\\blegal protection\\b",
    "(?i)\\badvance diligence\\b",
    "(?i)\\bliability bounds?\\b",
    "(?i)\\blegal personhood\\b",
    "(?i)\\bbound agent (risk|autonomy)\\b",
    "(?i)\\bwill satisfy (regulators|judges|courts)\\b",
    "(?i)\\bfile[- ]ready\\b",
    "(?i)\\beliminates? risk\\b",
    "(?i)\\bguaranteed? (outcomes?|protection|isolation)\\b",
    "(?i)\\bimmunity from\\b",
    "(?i)\\bliability[- ]isolation\\b",
    "(?i)\\bshield(s|ed|ing)? (you|your|from liability)\\b",
    "(?i)\\bprotect(s|ed|ing)? (you|your) from liability\\b",
    "(?i)\\bincorporation generator\\b",
    "(?i)\\blegally homeless\\b",
    "(?i)\\bresponsible[- ]party\\b",
    "(?i)\\blegal American entity\\b"
  ],
  "blocked_publish_filenames": [
    "OPINION_OF_THE_COURT.md",
    "LITIGATOR_RED_TEAM_FINDINGS.md",
    "LITIGATOR_REGULATOR_LONGTAIL.md",
    "LITIGATOR_FINDINGS.md",
    "RED_TEAM_FINDINGS.md",
    "COURT_OPINION.md"
  ],
  "blocked_publish_filename_globs": [
    "LITIGATOR_*",
    "*_RED_TEAM_*",
    "OPINION_OF_THE_COURT*"
  ],
  "publish_pieces_catalog": ".public-gate/publish-pieces.json",
  "publish_process_paths": [
    ".public-gate/",
    "GATE_MANIFEST.json",
    ".PUBLIC_STAGING_ONLY"
  ],
  "publish_process_globs": [
    ".public-gate/*"
  ],
  "secret_patterns": [
    "(?i)(api[_-]?key|secret[_-]?key|access[_-]?token|auth[_-]?token|password|passwd|credential)\\s*[:=]\\s*['\\\"]?[a-zA-Z0-9_\\-]{12,}",
    "sk-[a-zA-Z0-9]{20,}",
    "ghp_[a-zA-Z0-9]{36,}",
    "gho_[a-zA-Z0-9]{36,}",
    "github_pat_[a-zA-Z0-9_]{20,}",
    "xox[baprs]-[a-zA-Z0-9\\-]{10,}",
    "AKIA[0-9A-Z]{16}",
    "-----BEGIN (RSA |OPENSSH |EC )?PRIVATE KEY-----"
  ]
}